# ---------------------------------------------------------------------------
# Database (PostgreSQL)
# ---------------------------------------------------------------------------
# Connection string used by the app, drizzle-kit, migrations and the seed.
DATABASE_URL=postgresql://horizon:horizon@localhost:5432/datak_horizon

# Values consumed by docker-compose to provision the local database.
POSTGRES_USER=horizon
POSTGRES_PASSWORD=horizon
POSTGRES_DB=datak_horizon
POSTGRES_PORT=5432

# ---------------------------------------------------------------------------
# Firebase Authentication — client (public, exposed to the browser)
# ---------------------------------------------------------------------------
NUXT_PUBLIC_FIREBASE_API_KEY=
NUXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NUXT_PUBLIC_FIREBASE_PROJECT_ID=
NUXT_PUBLIC_FIREBASE_APP_ID=

# ---------------------------------------------------------------------------
# Firebase Admin SDK — server only
# ---------------------------------------------------------------------------
# Path to the service account JSON for local development.
# In GCP, Application Default Credentials will be used automatically.
GOOGLE_APPLICATION_CREDENTIALS=credentials/serviceAccount.json
